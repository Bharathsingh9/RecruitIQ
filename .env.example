# HireGen AI - Environment Variable Settings Template
# Copy this file to '.env' and fill in your actual API keys and connection urls.

# API Keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
# If empty, HireGen AI automatically defaults to using a local SQLite file ('hiregen.db')
# Example: postgresql://username:password@hostname:5432/dbname?sslmode=require
DATABASE_URL=your_database_url_here

# GenAI Model configuration
LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage paths
CHROMA_DB_PATH=vector_store_data/chroma_db
SQLITE_DB_FILE=hiregen.db

# Debug logs trigger (Set to True to activate verbose outputs)
DEBUG=False
